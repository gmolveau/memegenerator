set shell := ["bash", "-euo", "pipefail", "-c"]
set dotenv-load := true

default:
    @just --list

install:
    uv sync --locked

install-dev:
    uv sync --locked --dev

upgrade:
    uv sync --upgrade

create-volumes:
    mkdir -p static/templates

run-dev: create-volumes
    uv run uvicorn src.web:app --reload --host 0.0.0.0 --port=8000

run-prod: create-volumes
    uv run uvicorn src.web:app --host 0.0.0.0 --port=8000

new-migrate name:
    uv run alembic -c src/migrations/alembic.ini revision --autogenerate -m {{ name }}

migrate:
    uv run alembic -c src/migrations/alembic.ini upgrade head

ruff:
    uv run ruff check . --fix
    uv run ruff format .

ruff-check:
    uv run ruff check src tests cli migrations
    uv run ruff format --check src src tests cli migrations

ty:
    uv run ty check src tests cli migrations

bandit:
    uv run bandit -c pyproject.toml -r src

alembic-check:
    uv run alembic -c src/migrations/alembic.ini check

checks: ty ruff-check bandit

format: ruff

clean:
    rm -rf .venv
    find . -type f -name '*.pyc' -delete
    find . -type d -name '__pycache__' -delete
    find . -type d -name '.ty_cache ' -delete
    find . -type d -name '.pytest_cache ' -delete
    find . -type d -name '.ruff_cache' -delete
    rm -f coverage coverage.xml
    rm -rf .report
