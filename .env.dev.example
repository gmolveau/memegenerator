# see `docs/env.md`
### Backend
# CORS
ALLOWED_HOSTS="app.localhost,localhost:5173,localhost"
ALLOWED_ORIGINS="http://app.localhost,http://localhost:5173"

# Auth Keycloak / OIDC
KEYCLOAK_CLIENT_ID=the-app
KEYCLOAK_CLIENT_SECRET=L0nrBUABwIm3ghXrrXmoX76BJ6xjzDvy_wzDff6rKQ0
KEYCLOAK_AUTHORIZE_URL=http://keycloak.localhost/realms/myrealm/protocol/openid-connect/auth
KEYCLOAK_ACCESS_TOKEN_URL=http://keycloak.localhost/realms/myrealm/protocol/openid-connect/token
KEYCLOAK_JWT_URL=http://keycloak.localhost/realms/myrealm/protocol/openid-connect/certs
# uncomment when running without docker compose
# KEYCLOAK_AUTHORIZE_URL=http://localhost:8080/realms/myrealm/protocol/openid-connect/auth
# KEYCLOAK_ACCESS_TOKEN_URL=http://localhost:8080/realms/myrealm/protocol/openid-connect/token
# KEYCLOAK_JWT_URL=http://localhost:8080/realms/myrealm/protocol/openid-connect/certs

# Session
SESSION_SECRET_KEY=2gnHEC3puiDzkWab5OoQHJ96Y3xFJ5bWAoc2lc_jXv8
SESSION_COOKIE_BASE_DOMAIN=localhost
SESSION_COOKIE_MAX_AGE=86400

# Storage
STORAGE_LOCAL_PATH=./static/templates
STORAGE_LOCAL_BASE_URL=/static/templates

# Environment
APP_ENV="dev"

# Rate limiting (slowapi format: "N/second|minute|hour|day")
RATE_LIMIT="60/minute"

### Frontend
PUBLIC_API_URL=http://app.localhost/api
PUBLIC_BASE_URL=http://app.localhost
# uncomment only to run without docker compose
# PUBLIC_API_URL=http://localhost:8000
# PUBLIC_BASE_URL=http://localhost:5173

### Docker
DATA_FOLDER=./backend/data
STATIC_FOLDER=./backend/static
